# =============================================================================
# V2 risk-control flags — EXAMPLE FILE. Do NOT copy over your real .env.
# Append the lines you want to ~/bot/.env (EC2) or .env (local), then:
#   sudo systemctl restart bot-executor
#
# ALL flags default to OFF. With nothing set (or everything =0) the executor
# behaves exactly like V1. Full semantics: docs/SAFETY_CONTROLS.md §5.
# Enablement guide + suggested values: docs/OPERATIONS_RUNBOOK.md §3.
# =============================================================================

# Master off-switch. 1 = V2 risk layer never initializes; executor is pure V1.
# Use this to rule V2 out while debugging without deleting the other lines.
V2_RISK_DISABLED=0

# Time-stop: close any position held >= N minutes (exit reason EXIT_TIME).
# 0 = off. TP/SL always has priority; wall-clock based; scale-ins do NOT
# refresh the clock. 240 mirrors run.json MAX_HOLD_BARS=48 x 5m bars.
V2_TIME_STOP_MIN=0

# Daily stop-loss budget: after N EXIT_SL* closes in a UTC day, block NEW
# entries until midnight UTC (TP/SL/time-stop exits keep working). 0 = off.
V2_MAX_SL_PER_DAY=0

# Daily loss limit: while today's realized PnL <= -X USDT, block new entries.
# Net sum — later winning exits can lift the block. 0 = off.
V2_DAILY_LOSS_LIMIT_USDT=0

# Daily drawdown pause: while today's realized PnL sits >= X USDT below its
# intraday peak, block new entries. Catches "up big, giving it all back" days
# that the loss limit misses. 0 = off.
V2_DAILY_DD_LIMIT_USDT=0

# Pause file (kill switch): if this file exists, new entries are blocked within
# one poll (~3 s) — no restart, no .env edit. Delete the file to resume.
# Always armed (even with all flags above at 0) unless V2_RISK_DISABLED=1.
# Path is relative to the project root.
V2_PAUSE_FILE=run/V2_PAUSE

# Where V2 persists its daily counters and position entry-times.
# Counters are rebuilt from logs/trades_closed_YYYYMMDD.csv on restart, so
# deleting this file cannot reset today's SL count. Mainly a test override.
V2_RISK_STATE=logs/v2_risk_state.json


# =============================================================================
# Experimental ML/risk modules - documentation only, all default OFF.
# These flags are read through the same config/run.json -> .env loading chain.
# Leave them 0/false until the corresponding training artifact and live
# inference module have been added and validated in paper mode.
# =============================================================================

# Isolation Forest anomaly filter. Phase 2 runs this in shadow mode and writes
# logs/isolation_forest_shadow.csv. Blocking is disabled by default and only
# applies when USE_ISOLATION_FOREST=true and ISOLATION_FOREST_BLOCKING=true.
USE_ISOLATION_FOREST=false
ISOLATION_FOREST_BLOCKING=false
ISOLATION_FOREST_ARTIFACT=model_artifacts/isolation_forest.joblib

# XGBoost signal confirmation. Blocking is disabled by default and only applies
# when USE_XGBOOST_SIGNAL=true and XGBOOST_SIGNAL_BLOCKING=true.
USE_XGBOOST_SIGNAL=false
XGBOOST_SIGNAL_BLOCKING=false

# Survival Analysis exit model. Later phase: estimate duration/exit risk for
# timeout or early-exit decisions.
USE_SURVIVAL_EXIT=false

# Advanced risk management. Later phase: extra daily/open-trade/loss-cooldown
# and volatility-sizing controls.
USE_ADVANCED_RISK=false
